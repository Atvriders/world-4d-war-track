{
  "name": "world-4d-war-track",
  "version": "0.1.0",
  "description": "Real-time 4D global intelligence dashboard — live aircraft, vessels, satellites, conflict zones, and GPS jamming on an interactive 3D globe",
  "author": "Atvriders",
  "repository": {
    "type": "git",
    "url": "https://github.com/Atvriders/world-4d-war-track.git"
  },
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "server": "cd server && node --loader ts-node/esm src/server.ts",
    "dev:all": "concurrently \"npm run dev\" \"npm run server\""
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-globe.gl": "^2.27.1",
    "three": "^0.165.0",
    "satellite.js": "^5.0.0",
    "zustand": "^4.5.4",
    "axios": "^1.7.2",
    "d3-color": "^3.1.0",
    "date-fns": "^3.6.0",
    "concurrently": "^8.2.2"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.165.0",
    "@types/d3-color": "^3.1.3",
    "@vitejs/plugin-react": "^4.3.1",
    "typescript": "^5.4.5",
    "vite": "^5.3.1"
  }
}
